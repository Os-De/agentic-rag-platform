{
  "uid": "rag-platform",
  "title": "RAG Platform — Service & Agent Health",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Agent error ratio",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{outcome=\"error\"}[5m])) / clamp_min(sum(rate(rag_requests_total[5m])), 1e-9)",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Agent latency p95 by provider (s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_agent_seconds_bucket[10m])) by (le, provider))",
          "legendFormat": "{{provider}} p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Query rewrites & analyzer corrections (per min)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(rag_query_rewrites_total[5m]) * 60", "legendFormat": "rewrites/min" },
        { "expr": "rate(rag_query_corrections_total[5m]) * 60", "legendFormat": "corrections/min" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Avg best retrieval score (KB coverage)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(rag_retrieval_top_score_sum[30m])) / clamp_min(sum(rate(rag_retrieval_top_score_count[30m])), 1e-9)",
          "legendFormat": "avg top score (30m)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Chat throughput by provider (req/min)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{outcome=\"success\"}[5m])) by (provider) * 60",
          "legendFormat": "{{provider}}"
        }
      ]
    }
  ]
}

# ── Copy to .env and edit. Never commit .env. ──────────────────────────────

# App
ENVIRONMENT=dev                    # dev | prod  (prod => JSON logs)
LOG_LEVEL=INFO
CORS_ORIGINS=*                     # prod: exact origins, e.g. https://rag.example.com

# Security (CHANGE THESE)
JWT_SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_EMAIL=admin@example.com      # seeded on first startup
ADMIN_PASSWORD=admin123            # dev only — rotate in prod
RATE_LIMIT_LOGIN=10/minute         # slowapi syntax (per client IP)
RATE_LIMIT_CHAT=30/minute

# Database (compose overrides host to 'postgres')
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag

# Qdrant (compose overrides host to 'qdrant')
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base

# ── LLM providers — default provider + per-request override ────────────────
LLM_PROVIDER=ollama                # ollama | openai | anthropic
LLM_TEMPERATURE=0.1

# Ollama (local, free — https://ollama.com). Compose uses host.docker.internal.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b           # Arabic-heavy corpus? try qwen2.5:7b

# API providers (only needed if you use them)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Embeddings (see ADR-003) ────────────────────────────────────────────────
EMBEDDING_PROVIDER=fastembed       # fastembed | ollama | openai
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
# For Arabic/multilingual documents: intfloat/multilingual-e5-large (re-ingest required)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── RAG tuning ──────────────────────────────────────────────────────────────
RETRIEVAL_MODE=dense               # dense | hybrid (BM25+dense fusion; new collections only)
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=4
MAX_QUERY_REWRITES=1
HISTORY_MAX_TURNS=6                # conversation memory per conversation_id

# ── Production compose only (docker-compose.prod.yml reads from shell env) ──
# DOMAIN=rag.example.com
# POSTGRES_PASSWORD=<strong-password>
# GRAFANA_PASSWORD=<strong-password>
# WEB_CONCURRENCY=4

# ── OpenTelemetry LLM tracing (ADR-011) — self-hosted, data stays local ────
TRACING_BACKEND=none               # none | phoenix (OpenInference) | traceloop (OpenLLMetry)
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
OTLP_ENDPOINT=http://localhost:4318
# Run the backends: docker compose --profile tracing up -d
#   Phoenix UI: http://localhost:6006 · Jaeger UI: http://localhost:16686

# ── Observability: LangSmith (Phase 5) — https://smith.langchain.com ───────
LANGSMITH_TRACING=false            # set true to enable tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag-platform
# Legacy variable names (older langchain versions):
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-rag-platform
